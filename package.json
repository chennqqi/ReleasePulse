{
  "name": "release-pulse",
  "version": "1.0.0",
  "description": "Browser extension for subscribing to software release notifications (GitHub releases, tags, issues)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && node scripts/patch-firefox-manifest.mjs",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "firefox:lint": "node scripts/verify-firefox.mjs",
    "firefox:run": "web-ext run --source-dir dist",
    "firefox:verify": "npm run build && npm run firefox:lint",
    "firefox:zip": "node scripts/pack-store-zip.mjs firefox",
    "chrome:zip": "node scripts/pack-store-zip.mjs chrome",
    "release:pack": "node scripts/build-release.mjs",
    "release:verify": "node scripts/check-version-sync.mjs && npm run test && npm run build && npm run firefox:lint"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.5",
    "lucide-react": "^0.408.0",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.25",
    "@types/chrome": "^0.0.270",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^2.1.8",
    "web-ext": "^8.10.0"
  }
}
